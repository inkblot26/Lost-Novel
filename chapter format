<!DOCTYPE html>
<html>
<head>
    <title>Chapter Reader</title>

    <style>
        body {
            margin: 0;
            background-color: #ffffff;
            color: #222;
            font-family: Georgia, serif;
            transition: 0.3s ease;
        }

        /* ===== TOP BAR ===== */
        .top-bar {
            position: sticky;
            top: 0;
            background: #ffffff;
            border-bottom: 1px solid #ddd;
            padding: 10px 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 50;
        }

        body.dark .top-bar {
            background: #121212;
            border-bottom: 1px solid #333;
        }

        .book-info {
            display: flex;
            flex-direction: column;
        }

        .book-title {
            font-weight: bold;
            font-size: 14px;
        }

        .chapter-title {
            font-size: 13px;
            opacity: 0.7;
        }

        .top-buttons button {
            margin-left: 10px;
            padding: 6px 10px;
            cursor: pointer;
            border: none;
            border-radius: 5px;
        }

        /* ===== READER AREA ===== */
        .content {
            max-width: 800px;
            margin: 0 auto;
            padding: 30px 20px;
        }

        .chapter {
            white-space: pre-wrap;
            font-size: 24px;
            line-height: 1.8;
            text-align: justify;
        }

        /* ===== NAV ===== */
        .nav {
            margin-top: 50px;
            padding-top: 20px;
            border-top: 1px solid #ccc;
            display: flex;
            justify-content: center;
            gap: 40px;
        }

        .nav a {
            text-decoration: none;
            font-weight: bold;
            color: #0066cc;
        }

        /* ===== DARK MODE ===== */
        body.dark {
            background-color: #0f0f0f;
            color: #e6e6e6;
        }

        body.dark a {
            color: #9ecbff;
        }

        body.dark .nav a {
            color: #9ecbff;
        }

        body.dark .chapter {
            color: #e6e6e6;
        }

        body.dark .top-bar {
            color: #fff;
        }

        /* ===== SETTINGS PANEL ===== */
        .reader-settings {
            position: fixed;
            top: 60px;
            right: 15px;
            background: rgba(255,255,255,0.95);
            padding: 10px;
            border-radius: 8px;
            display: none;
            flex-direction: column;
            gap: 8px;
            font-size: 14px;
            z-index: 100;
        }

        body.dark .reader-settings {
            background: rgba(30,30,30,0.95);
        }
    </style>
</head>

<body>

<!-- ===== TOP BAR ===== -->
<div class="top-bar">
    <div class="book-info">
        <div class="book-title">Lost: Ashes of Vengeance</div>
        <div class="chapter-title" id="chapterTitle">Loading...</div>
    </div>

    <div class="top-buttons">
        <button onclick="toggleSettings()">⚙</button>
        <button onclick="toggleMode()">🌙 / ☀</button>
    </div>
</div>

<!-- ===== SETTINGS ===== -->
<div class="reader-settings" id="settingsPanel">
    <label>Font Size</label>
    <select id="fontSize" onchange="changeFontSize()">
        <option value="20px">Small</option>
        <option value="24px" selected>Medium</option>
        <option value="28px">Large</option>
        <option value="32px">Extra Large</option>
    </select>

    <label>Font</label>
    <select id="fontFamily" onchange="changeFontFamily()">
        <option value="Georgia">Georgia</option>
        <option value="Arial">Arial</option>
        <option value="Verdana">Verdana</option>
    </select>

    <label>Line Height</label>
    <select id="lineHeight" onchange="changeLineHeight()">
        <option value="1.5">Compact</option>
        <option value="1.8" selected>Normal</option>
        <option value="2.1">Relaxed</option>
    </select>

    <label>Width</label>
    <select id="readingWidth" onchange="changeReadingWidth()">
        <option value="600px">Narrow</option>
        <option value="800px" selected>Normal</option>
        <option value="1000px">Wide</option>
    </select>
</div>

<!-- ===== CONTENT ===== -->
<div class="content" id="reader">
    <div class="chapter" id="chapterText">Loading chapter...</div>

    <div class="nav">
        <a href="/Lost-Novel/">Home</a>
    </div>
</div>

<script>
/* =========================
   DARK MODE
========================= */
function toggleMode() {
    document.body.classList.toggle("dark");
    localStorage.setItem("mode",
        document.body.classList.contains("dark") ? "dark" : "light"
    );
}

if (localStorage.getItem("mode") === "dark") {
    document.body.classList.add("dark");
}

/* =========================
   SETTINGS TOGGLE
========================= */
function toggleSettings() {
    const panel = document.getElementById("settingsPanel");
    panel.style.display = panel.style.display === "flex" ? "none" : "flex";
}

/* =========================
   LOAD CHAPTER FROM TXT
========================= */
const params = new URLSearchParams(window.location.search);
const file = params.get("file") || "book1/ch001.txt"; // default chapter

fetch(file)
    .then(res => res.text())
    .then(text => {
        document.getElementById("chapterText").innerText = text;

        const firstLine = text.split("\n")[0];
        document.getElementById("chapterTitle").innerText = firstLine;
    })
    .catch(() => {
        document.getElementById("chapterText").innerText = "Failed to load chapter.";
    });

/* =========================
   SETTINGS SYSTEM
========================= */
function changeFontSize() {
    const v = document.getElementById("fontSize").value;
    document.getElementById("reader").style.fontSize = v;
    localStorage.setItem("fontSize", v);
}

function changeFontFamily() {
    const v = document.getElementById("fontFamily").value;
    document.getElementById("reader").style.fontFamily = v;
    localStorage.setItem("fontFamily", v);
}

function changeLineHeight() {
    const v = document.getElementById("lineHeight").value;
    document.getElementById("reader").style.lineHeight = v;
    localStorage.setItem("lineHeight", v);
}

function changeReadingWidth() {
    const v = document.getElementById("readingWidth").value;
    document.getElementById("reader").style.maxWidth = v;
    localStorage.setItem("readingWidth", v);
}

/* =========================
   LOAD SAVED SETTINGS
========================= */
window.onload = function () {

    const fs = localStorage.getItem("fontSize");
    if (fs) {
        document.getElementById("reader").style.fontSize = fs;
        document.getElementById("fontSize").value = fs;
    }

    const ff = localStorage.getItem("fontFamily");
    if (ff) {
        document.getElementById("reader").style.fontFamily = ff;
        document.getElementById("fontFamily").value = ff;
    }

    const lh = localStorage.getItem("lineHeight");
    if (lh) {
        document.getElementById("reader").style.lineHeight = lh;
        document.getElementById("lineHeight").value = lh;
    }

    const rw = localStorage.getItem("readingWidth");
    if (rw) {
        document.getElementById("reader").style.maxWidth = rw;
        document.getElementById("readingWidth").value = rw;
    }
};
</script>

</body>
</html>
